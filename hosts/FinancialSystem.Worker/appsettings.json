{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=financialsystem;Username=postgres;Password=postgres"
  },
  "FileIngestion": {
    "ImportsPath": "C:\\Colo\\Programas\\FinancialMcp\\Imports",
    "DebounceMilliseconds": 750,
    "_ImportsPathHelp": "Omit or leave ImportsPath empty to use <executable-dir>/imports. Examples: Linux absolute '/imports', Windows absolute 'C:\\\\imports', relative to content root 'imports' or 'data/incoming'."
  },
  "FileIngestion:Pdf": {
    "MinDescriptionLength": 2,
    "MaxDescriptionLength": 512,
    "IgnoreLineContains": [
      "RESUMEN DE CUENTA",
      "TOTAL A PAGAR",
      "SALDO ANTERIOR",
      "SALDO ACTUAL",
      "PAGINA",
      "PÁGINA",
      "LEGALES",
      "TNA ",
      "TEA ",
      "CFT "
    ],
    "LinePatterns": [
      "^(?<date>\\d{2}/\\d{2}/\\d{2,4})\\s+(?<desc>.+?)\\s+(?<amount>-?[\\d.,]+)\\s*$",
      "^(?<date>\\d{2}-\\d{2}-\\d{2,4})\\s+(?<desc>.+?)\\s+(?<amount>-?[\\s\\d.,]+)\\s*$"
    ]
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3.2",
    "TimeoutSeconds": 120
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "TimeoutSeconds": 120
  },
  "InsightsWorker": {
    "Enabled": true,
    "Provider": "Ollama",
    "IntervalMinutes": 5,
    "TransactionBatchSize": 50
  }
}
