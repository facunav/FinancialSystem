{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=financialsystem;Username=postgres;Password=postgres"
  },
  "FileIngestion": {
    "ImportsPath": "C:\\Colo\\Programas\\FinancialMcp\\Imports",
    "DebounceMilliseconds": 750,
    "ManualExpenseFilePatterns": [
      "Cuentas*.xlsx",
      "*manual*.xlsx",
      "*gastos*.xlsx"
    ],
    "BbvaBankStatementFilePatterns": [
      "Caja*.xls",
      "*ahorros*.xls",
      "*corriente*.xls"
    ],
    "_ImportsPathHelp": "Omit or leave ImportsPath empty to use <executable-dir>/imports. Examples: Linux absolute '/imports', Windows absolute 'C:\\\\imports', relative to content root 'imports' or 'data/incoming'."
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3.2",
    "TimeoutSeconds": 120
  },
  "OpenAI": {
    "ApiKey": "",
    "Model": "gpt-4o-mini",
    "TimeoutSeconds": 120
  },
  "InsightsWorker": {
    "Enabled": true,
    "Provider": "Ollama",
    "IntervalMinutes": 5,
    "TransactionBatchSize": 50
  },
  "Reconciliation": {
    "HighConfidenceThreshold": 0.85,
    "MediumConfidenceThreshold": 0.60,
    "NearMissThreshold": 0.35,
    "AmountAbsoluteTolerance": 50.0,
    "AmountRelativeTolerance": 0.02,
    "DateWindowDays": 3,
    "AmountRuleWeight": 0.45,
    "DateRuleWeight": 0.25,
    "DescriptionRuleWeight": 0.20,
    "PaymentMethodRuleWeight": 0.10
  }
}
